{
  "name": "effect-tanstack-start",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run src/lib src/api src/features src/routes/api/-lib src/*.test.ts --exclude src/lib/atom-hydration.test.tsx --exclude src/lib/posthog-client.test.ts",
    "test:component": "vitest run src/component/*.test.tsx src/routes/-index/*.test.tsx src/lib/atom-hydration.test.tsx --browser.enabled=true",
    "test:browser": "bunx vitest run src/component/*.test.tsx src/routes/-index/*.test.tsx src/lib/atom-hydration.test.tsx --browser.enabled=true --project=chromium",
    "test:visual": "vitest run src/visual/*.test.tsx --browser.enabled=true --browser.fileParallelism=false",
    "test:visual:update": "vitest run src/visual/*.test.tsx --browser.enabled=true --browser.fileParallelism=false --update",
    "test:watch": "vitest",
    "test:coverage": "mkdir -p coverage/.tmp && vitest run src/lib src/api src/features src/routes/api/-lib src/routes/api/$.test.ts src/*.test.ts tests/lint-design-system-lib.test.ts --exclude src/lib/atom-hydration.test.tsx --exclude src/lib/posthog-client.test.ts --coverage",
    "test:coverage:ui": "vitest run --coverage --ui",
    "typecheck": "tsgo --noEmit -p tsconfig.json",
    "typecheck:legacy": "tsc --noEmit -p tsconfig.json",
    "lint": "node ./node_modules/oxlint/bin/oxlint --config oxlint.config.js .",
    "lint:fix": "node ./node_modules/oxlint/bin/oxlint --config oxlint.config.js --fix .",
    "lint:type-aware": "node ./node_modules/oxlint/bin/oxlint --config oxlint.config.js --type-aware --deny-warnings .",
    "lint:design-system": "bun run scripts/lint-design-system.ts",
    "lint:design-system:staged": "bun run scripts/lint-design-system-staged.ts",
    "lint:design-system:changed": "bun run scripts/lint-design-system-changed.ts",
    "format": "dprint fmt",
    "format:check": "dprint check",
    "docs:check": "bun run scripts/check-docs-quality.ts",
    "analyze": "vite build --mode analyze",
    "size": "bun run scripts/check-bundle-size.ts",
    "perf:check": "bun run build && bun run size",
    "prepare": "effect-language-service patch && effect-tsgo patch",
    "postinstall": "bash scripts/install-git-hooks.sh",
    "validate": "bun run typecheck && bun run lint && bun run lint:type-aware && bun run lint:design-system && bun run format:check && bun run docs:check && bun run test:coverage && bun run test:browser && bun run perf:check"
  },
  "dependencies": {
    "@datadog/pprof": "github:SamuelLHuber/pprof-nodejs#pyroscope-ts-bun-compat-2026-02-10",
    "@effect/atom-react": "4.0.0-beta.47",
    "@effect/platform-browser": "4.0.0-beta.47",
    "@electric-sql/pglite": "^0.3.7",
    "@opentelemetry/exporter-logs-otlp-http": "0.208.0",
    "@pyroscope/nodejs": "^0.4.9",
    "@sentry/effect": "^10.51.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/router-plugin": "^1.132.0",
    "drizzle-orm": "^0.45.1",
    "effect": "4.0.0-beta.47",
    "lucide-react": "^0.544.0",
    "nitro": "latest",
    "postgres": "^3.4.7",
    "posthog-js": "^1.306.1",
    "posthog-node": "^5.17.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.0.6",
    "vite-tsconfig-paths": "^5.1.4"
  },
  "overrides": {
    "@datadog/pprof": "github:SamuelLHuber/pprof-nodejs#pyroscope-ts-bun-compat-2026-02-10"
  },
  "devDependencies": {
    "@antithesishq/bombadil": "^0.3.2",
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.62.2",
    "@effect/opentelemetry": "4.0.0-beta.47",
    "@effect/tsgo": "0.7.2",
    "@effect/vitest": "4.0.0-beta.47",
    "@opentelemetry/exporter-trace-otlp-http": "^0.208.0",
    "@opentelemetry/sdk-metrics": "^2.2.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/sdk-trace-node": "^2.2.0",
    "@opentelemetry/sdk-trace-web": "^2.2.0",
    "@sentry/node": "^10.30.0",
    "@sentry/opentelemetry": "^10.30.0",
    "@sentry/react": "^10.30.0",
    "@tanstack/devtools-vite": "^0.3.11",
    "@tanstack/react-devtools": "^0.8.4",
    "@tanstack/react-router-devtools": "^1.141.2",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/utils": "8.49.0",
    "@typescript/native-preview": "^7.0.0-dev.20260325.1",
    "@vitejs/plugin-react": "^5.0.4",
    "@vitest/browser": "^4.0.15",
    "@vitest/browser-playwright": "^4.0.15",
    "@vitest/coverage-istanbul": "^4.0.15",
    "@vitest/coverage-v8": "^4.0.15",
    "dprint": "^0.47.2",
    "eslint-plugin-jsdoc": "^61.5.0",
    "oxlint": "^1.51.0",
    "oxlint-tsgolint": "^0.17.4",
    "playwright": "^1.57.0",
    "react-grab": "^0.1.21",
    "smithers-orchestrator": "0.12.3",
    "typescript": "^5.7.2",
    "vite": "^7.1.7",
    "vitest": "^4.0.15",
    "vitest-browser-react": "^2.0.2",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.6"
  },
  "patchedDependencies": {
    "srvx@0.9.7": "patches/srvx@0.9.7.patch",
    "nitro@3.0.1-alpha.1": "patches/nitro@3.0.1-alpha.1.patch"
  }
}
